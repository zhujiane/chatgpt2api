{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend API (uvicorn:8001)",
      "type": "node-terminal",
      "request": "launch",
      "command": "source /c/Users/zhujiancc/Desktop/githubs/chatgpt2api/.venv/Scripts/activate && python main.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "HOST": "127.0.0.1",
        "PORT": "8001",
        "STORAGE_BACKEND": "postgres",
        "DATABASE_URL": "postgresql://chatgpt2api:chatgpt2api_password@localhost:5432/chatgpt2api",
        "CHATGPT2API_REGISTER_AUTOSTART": "false",
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Frontend Web (Next.js:8000)",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "cwd": "${workspaceFolder}/web",
      "env": {
        "NEXT_PUBLIC_API_URL": "http://127.0.0.1:8001"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug (F5)",
      "configurations": [
        "Backend API (uvicorn:8001)",
        "Frontend Web (Next.js:8000)"
      ],
      "stopAll": true
    }
  ]
}
